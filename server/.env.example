# Hono server — copy to server/.env and fill in.
# Loaded by `loadEnvFile()` from node:process at server startup.
# PM2's env block (in ../ecosystem.config.cjs) takes precedence over this file.

# Networking
PORT=3300
# NODE_ENV is set by PM2 (development | production); leave unset locally.

# MongoDB Atlas
MONGODB_URI=
# Voyage (embeddings + reranker)
VOYAGE_API_KEY=

# Anthropic (LLM judge + answer generator)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_JUDGE=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_GENERATOR=claude-sonnet-4-6

# Logging
LOG_LEVEL=info
