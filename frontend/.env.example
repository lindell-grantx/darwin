# Absolute URL of the Hono API server (no trailing slash).
# Dev (PM2): http://localhost:3300 (set in ../ecosystem.config.cjs)
# Prod:     https://api.darwin.example.com
VITE_API_URL=http://localhost:3300

# When true, the UI serves mock fixtures instead of hitting the API.
# Default: true (so the UI works standalone). Set to "false" in prod.
VITE_USE_MOCKS=false
