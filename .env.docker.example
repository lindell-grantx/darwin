# Darwin v2 docker-compose env file
# Copy to .env.docker and fill in your credentials.

# Required
MONGODB_URI=mongodb+srv://USER:PASSWORD@YOUR-CLUSTER/darwin?retryWrites=true&w=majority
VOYAGE_API_KEY=your-voyage-api-key

# Pick one auth path for Anthropic:
# Option A: direct Anthropic API key (simplest)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Option B: Vertex AI (uncomment + set instead of ANTHROPIC_API_KEY)
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project
# CLOUD_ML_REGION=global

# Optional
LOG_LEVEL=info
